# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional site-wide notice: level is info, warning, or critical
NEXT_PUBLIC_SITE_NOTICE=
NEXT_PUBLIC_SITE_NOTICE_LEVEL=info
NEXT_PUBLIC_SITE_NOTICE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Administrators (comma-separated email addresses)
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_WECHAT=

# Default AI provider: openai or deepseek
AI_PROVIDER=deepseek

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MODEL_OPTIONS=
OPENAI_POINT_COST=1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_MODEL_OPTIONS=
DEEPSEEK_POINT_COST=1

# Chat safety and limits
CHAT_RATE_LIMIT=20
CHAT_RATE_WINDOW_SECONDS=60
CHAT_DAILY_POINT_LIMIT=200

# Recharge orders
ORDER_EXPIRY_HOURS=24

# Online payment guardrails
# Keep disabled until one real provider is fully configured and webhook URLs are set.
ONLINE_PAYMENTS_ENABLED=false
# Supported values: alipay, wechat, stripe, manual
PAYMENT_PROVIDER=manual

# Alipay Open Platform - Computer Website Payment
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# WeChat Pay v3 - Native QR Code Payment
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_MCH_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_API_V3_KEY=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_NOTIFY_URL=

# Stripe fallback, optional
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=cny
STRIPE_PAYMENT_METHOD_TYPES=card

# Optional order emails via Resend
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
