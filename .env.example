# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional site-wide notice: level is info, warning, or critical
NEXT_PUBLIC_SITE_NOTICE=
NEXT_PUBLIC_SITE_NOTICE_LEVEL=info
NEXT_PUBLIC_SITE_NOTICE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Administrators (comma-separated email addresses)
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_WECHAT=

# Default AI provider: openai or deepseek
AI_PROVIDER=deepseek

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MODEL_OPTIONS=
OPENAI_POINT_COST=1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_MODEL_OPTIONS=
DEEPSEEK_POINT_COST=1

# Chat safety and limits
CHAT_RATE_LIMIT=20
CHAT_RATE_WINDOW_SECONDS=60
CHAT_DAILY_POINT_LIMIT=200

# Recharge orders
ORDER_EXPIRY_HOURS=24

# Online payment guardrails
# Keep disabled until Stripe keys and webhook signing secret are configured.
ONLINE_PAYMENTS_ENABLED=false
# Supported values: stripe, manual. WeChat/Alipay can be enabled inside Stripe.
PAYMENT_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=cny
STRIPE_PAYMENT_METHOD_TYPES=card,alipay,wechat_pay

# Optional order emails via Resend
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
